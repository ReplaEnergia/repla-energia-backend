{
  "version": 2,
  "builds": [
    {
      "src": "src/api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "(.*)",
      "dest": "src/api/index.ts"
    }
  ],
  "crons": [
    {
      "path": "/api/reviews/force-refresh",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/gallery/debug?refresh=true",
      "schedule": "30 3 * * *"
    }
  ]
}